# SENTINEL — Environment Variables
# Copy this file to .env and fill in your API keys.
# Keys are OPTIONAL: without them the local knowledge base still works.
# With at least one key, the LLM tier (Layer 2) activates automatically.
#
# ĐỀ XUẤT: Bắt đầu với Groq (nhanh nhất, miễn phí) hoặc Gemini.
# Thứ tự ưu tiên mặc định: groq -> gemini -> openrouter -> together -> huggingface

# ── LLM Provider API Keys ──────────────────────────────────────────────────────

# Groq — https://console.groq.com (nhanh nhất, miễn phí, ĐỀ XUẤT #1)
# Đăng ký miễn phí, quota rất tốt cho llama-3.3-70b-versatile
GROQ_API_KEY=

# Google Gemini — https://aistudio.google.com (ĐỀ XUẤT #2)
# Gemini 2.0 Flash miễn phí, chất lượng cao
GEMINI_API_KEY=

# OpenRouter — https://openrouter.ai (free models available, ĐỀ XUẤT #3)
OPENROUTER_API_KEY=

# Together.ai — https://api.together.xyz (free $1 credit, Llama 70B)
TOGETHER_API_KEY=

# HuggingFace Inference API — https://huggingface.co/settings/tokens (free tier)
HF_API_KEY=

# ── LLM Router Config (all optional, defaults shown) ──────────────────────────

# Provider selection order (comma-separated IDs)
# NÂNG CẤP: Groq đứng đầu vì nhanh nhất và miễn phí
# VITE_LLM_PROVIDER_PRIORITY=groq,gemini,openrouter,together,huggingface

# Request timeout per provider (ms) — NÂNG CẤP: tăng từ 12000 -> 20000
# VITE_LLM_TIMEOUT_MS=20000

# Max retries per provider on transient error
# VITE_LLM_MAX_RETRIES=2

# Cache TTL for repeated questions (ms) — NÂNG CẤP: tăng lên 10 phút
# VITE_LLM_CACHE_TTL_MS=600000

# Enable cross-checking with 2 providers (true/false)
# VITE_LLM_CROSS_CHECK_ENABLED=true

# Confidence threshold below which cross-check is triggered (0-1)
# NÂNG CẤP: giảm từ 0.65 -> 0.55 (ít cross-check hơn, tiết kiệm quota)
# VITE_LLM_CROSS_CHECK_THRESHOLD=0.55

# Max tokens to send in prompt (input guard)
# NÂNG CẤP: tăng từ 1500 -> 2500 để gửi nhiều ngữ cảnh hơn
# VITE_LLM_MAX_INPUT_TOKENS=2500

# Max tokens to request from provider (output guard)
# NÂNG CẤP QUAN TRỌNG: tăng từ 512 -> 2048 để có câu trả lời đầy đủ hơn
# VITE_LLM_MAX_OUTPUT_TOKENS=2048

# Số turn hội thoại gửi lên LLM (history window)
# VITE_LLM_HISTORY_TURNS=20

# ── Model overrides (optional) ─────────────────────────────────────────────────

# NÂNG CẤP: Groq 70B (mạnh hơn nhiều, miễn phí)
# VITE_GROQ_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant,llama3-8b-8192
# VITE_GROQ_TIMEOUT_MS=15000

# NÂNG CẤP: Gemini 2.0 Flash (model mới nhất)
# VITE_GEMINI_MODELS=gemini-2.0-flash,gemini-1.5-flash,gemini-2.0-flash-lite
# VITE_GEMINI_TIMEOUT_MS=20000

# NÂNG CẤP: OpenRouter Llama 70B (miễn phí)
# VITE_OPENROUTER_MODELS=meta-llama/llama-3.3-70b-instruct:free,meta-llama/llama-3.1-8b-instruct:free,mistralai/mistral-7b-instruct:free
# VITE_OPENROUTER_TIMEOUT_MS=20000

# VITE_TOGETHER_MODELS=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free,Qwen/Qwen2.5-72B-Instruct-Turbo
# VITE_TOGETHER_TIMEOUT_MS=20000

# VITE_HF_MODELS=Qwen/Qwen2.5-72B-Instruct,mistralai/Mistral-7B-Instruct-v0.3
# VITE_HF_TIMEOUT_MS=30000
