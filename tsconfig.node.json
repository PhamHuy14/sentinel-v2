{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "ignoreDeprecations": "5.0",
    "skipLibCheck": true,

    "outDir": "./dist-ts",
    "composite": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "paths": {
      "@engine/*": ["./engine/*"]
    }
  },
  "include": ["electron", "engine"]
}
