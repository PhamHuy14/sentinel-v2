{
  "name": "sentinel-v2",
  "version": "2.0.0",
  "description": "OWASP 2025 Security Workbench",
  "main": "dist-electron/main.js",
  "packageManager": "npm@10",
  "engines": {
    "node": ">=20 <21",
    "npm": ">=10 <11"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "lint": "npm run lint:renderer && npm run lint:node",
    "lint:fix": "npm run lint:renderer:fix && npm run lint:node:fix",
    "lint:renderer": "eslint src/ --ext .ts,.tsx",
    "lint:renderer:fix": "eslint src/ --ext .ts,.tsx --fix",
    "lint:node": "eslint electron/ engine/ --ext .js",
    "lint:node:fix": "eslint electron/ engine/ --ext .js --fix",
    "format": "prettier --write .",
    "typecheck": "npm run typecheck:renderer && npm run typecheck:node",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.json",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "dist": "npm run build && electron-builder --win portable",
    "clean": "rimraf dist dist-electron"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "undici": "^8.0.2",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^1.6.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.2",
    "rimraf": "^5.0.7",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^1.6.0"
  }
}
